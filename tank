<body>
<div class="game-wrapper">
    <div class="tip">⬆️ 八方向移动 · 🔴 开火 · 消灭全部敌人</div>
    <canvas id="gameBox" width="360" height="360"></canvas>

    <div class="control-wrap">
        <div class="dir-panel">
            <button class="btn" data-dir="upleft">↖</button>
            <button class="btn" data-dir="up">↑</button>
            <button class="btn" data-dir="upright">↗</button>
            <button class="btn" data-dir="left">←</button>
            <div></div>
            <button class="btn" data-dir="right">→</button>
            <button class="btn" data-dir="downleft">↙</button>
            <button class="btn" data-dir="down">↓</button>
            <button class="btn" data-dir="downright">↘</button>
        </div>
        <div class="fire-box">
            <button class="fire-btn" id="btnFire">🔥</button>
        </div>
    </div>
</div>

<!-- 真实通关音频 (好棒.MP3) 预加载 -->
<audio id="winSound" src="data:audio/mpeg;base64," preload="auto" style="display:none;"></audio>

<script>
    (function(){
        // ---------- 画布与上下文 ----------
        const canvas = document.getElementById('gameBox');
        const ctx = canvas.getContext('2d');
        // 使用固定逻辑尺寸 360x360
        const W = 360;
        const H = 360;
        const size = 30;

        // ---------- 音频系统 ----------
        let audioCtx = null;
        function initAudio() {
            if (!audioCtx) {
                audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            }
        }
        // 发射音效 (短促)
        function playShoot() {
            try {
                initAudio();
                const osc = audioCtx.createOscillator();
                const gain = audioCtx.createGain();
                osc.type = 'square';
                osc.frequency.setValueAtTime(800, audioCtx.currentTime);
                osc.frequency.exponentialRampToValueAtTime(200, audioCtx.currentTime + 0.1);
                gain.gain.setValueAtTime(0.12, audioCtx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.1);
                osc.connect(gain);
                gain.connect(audioCtx.destination);
                osc.start();
                osc.stop(audioCtx.currentTime + 0.1);
            } catch(_) {}
        }
        // 击中爆炸音效
        function playHit() {
            try {
                initAudio();
                const osc = audioCtx.createOscillator();
                const gain = audioCtx.createGain();
                osc.type = 'sawtooth';
                osc.frequency.setValueAtTime(150, audioCtx.currentTime);
                osc.frequency.exponentialRampToValueAtTime(30, audioCtx.currentTime + 0.25);
                gain.gain.setValueAtTime(0.2, audioCtx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.25);
                osc.connect(gain);
                gain.connect(audioCtx.destination);
                osc.start();
                osc.stop(audioCtx.currentTime + 0.25);
            } catch(_) {}
        }

        // 通关语音 (好棒.MP3) + 降级处理
        function playWinVoice() {
            const audio = document.getElementById('winSound');
            if (audio) {
                audio.currentTime = 0;
                audio.play().catch(() => {
                    // 降级: 合成简单胜利音
                    try {
                        initAudio();
                        const osc = audioCtx.createOscillator();
                        const gain = audioCtx.createGain();
                        osc.type = 'sine';
                        osc.frequency.setValueAtTime(800, audioCtx.currentTime);
                        osc.frequency.exponentialRampToValueAtTime(1300, audioCtx.currentTime + 0.6);
                        gain.gain.setValueAtTime(0.3, audioCtx.currentTime);
                        gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.8);
                        osc.connect(gain);
                        gain.connect(audioCtx.destination);
                        osc.start();
                        osc.stop(audioCtx.currentTime + 0.8);
                    } catch(_) {}
                });
            }
        }

        // ---------- 游戏对象 ----------
        const player = {
            x: W/2 - size/2,
            y: H - size*2,
            w: size,
            h: size,
            speed: 2.5,
            dir: 'up',
            color: '#3be83b'
        };

        let enemies = [
            { x: 30, y: 30, w: size, h: size, speed: 1.0, dir: 'down', color: '#f55' },
            { x: W - 60, y: 30, w: size, h: size, speed: 0.9, dir: 'down', color: '#f55' },
            { x: W/2 - size/2, y: 30, w: size, h: size, speed: 0.8, dir: 'right', color: '#f55' },
            { x: 30, y: 120, w: size, h: size, speed: 0.9, dir: 'left', color: '#f55' },
            { x: W - 60, y: 120, w: size, h: size, speed: 1.0, dir: 'up', color: '#f55' },
        ];

        // 墙体 (固定)
        const walls = [
            {x:90,y:90,w:size,h:size},{x:120,y:90,w:size,h:size},{x:150,y:90,w:size,h:size},
            {x:180,y:180,w:size,h:size},{x:210,y:180,w:size,h:size},{x:240,y:180,w:size,h:size},
            {x:90,y:240,w:size,h:size},{x:120,y:240,w:size,h:size}
        ];

        let bullets = [];
        const keys = {};

        // ---------- 触屏/鼠标 按键绑定 ----------
        function attachButtonListeners() {
            // 方向按钮
            document.querySelectorAll('.btn[data-dir]').forEach(btn => {
                const dir = btn.dataset.dir;
                const start = (e) => { e.preventDefault(); keys[dir] = true; };
                const end = (e) => { e.preventDefault(); keys[dir] = false; };
                btn.addEventListener('touchstart', start, {passive: false});
                btn.addEventListener('touchend', end, {passive: false});
                btn.addEventListener('touchcancel', end, {passive: false});
                btn.addEventListener('mousedown', start);
                btn.addEventListener('mouseup', end);
                btn.addEventListener('mouseleave', end);
            });

            // 开火按钮
            const fireBtn = document.getElementById('btnFire');
            const fireStart = (e) => { e.preventDefault(); keys.fire = true; };
            const fireEnd = (e) => { e.preventDefault(); keys.fire = false; };
            fireBtn.addEventListener('touchstart', fireStart, {passive: false});
            fireBtn.addEventListener('touchend', fireEnd, {passive: false});
            fireBtn.addEventListener('touchcancel', fireEnd, {passive: false});
            fireBtn.addEventListener('mousedown', fireStart);
            fireBtn.addEventListener('mouseup', fireEnd);
        }
        attachButtonListeners();

        // 键盘映射 (移动端外接键盘支持)
        window.addEventListener('keydown', (e) => {
            const map = {ArrowUp:'up',ArrowDown:'down',ArrowLeft:'left',ArrowRight:'right',Space:'fire'};
            if(map[e.code]) { e.preventDefault(); keys[map[e.code]] = true; }
        });
        window.addEventListener('keyup', (e) => {
            const map = {ArrowUp:'up',ArrowDown:'down',ArrowLeft:'left',ArrowRight:'right',Space:'fire'};
            if(map[e.code]) { e.preventDefault(); keys[map[e.code]] = false; }
        });

        // ---------- 碰撞检测 ----------
        function isCollide(a, b) {
            return a.x < b.x + b.w && a.x + a.w > b.x && a.y < b.y + b.h && a.y + a.h > b.y;
        }
        function hitWall(obj) {
            for(let w of walls) if(isCollide(obj, w)) return true;
            return false;
        }

        // ---------- 发射子弹 ----------
        function shoot() {
            let bx = player.x + size/2 - 3;
            let by = player.y + size/2 - 3;
            const spd = 6;
            const dir = player.dir;
            if(dir === 'up') by -= size/2;
            else if(dir === 'down') by += size/2;
            else if(dir === 'left') bx -= size/2;
            else if(dir === 'right') bx += size/2;
            else if(dir === 'upleft') { bx -= size/2; by -= size/2; }
            else if(dir === 'upright') { bx += size/2; by -= size/2; }
            else if(dir === 'downleft') { bx -= size/2; by += size/2; }
            else if(dir === 'downright') { bx += size/2; by += size/2; }
            bullets.push({x:bx, y:by, w:6, h:6, speed:spd, dir});
            playShoot();
        }
        let fireCd = 0;

        // ---------- 更新逻辑 ----------
        function update() {
            // 玩家移动 (八方向)
            let dx = 0, dy = 0;
            // 单独方向
            if(keys.up) { dy = -1; player.dir = 'up'; }
            else if(keys.down) { dy = 1; player.dir = 'down'; }
            if(keys.left) { dx = -1; player.dir = 'left'; }
            else if(keys.right) { dx = 1; player.dir = 'right'; }

            // 八方向按钮优先 (独立斜向)
            if(keys.upleft) { dx = -0.707; dy = -0.707; player.dir = 'upleft'; }
            else if(keys.upright) { dx = 0.707; dy = -0.707; player.dir = 'upright'; }
            else if(keys.downleft) { dx = -0.707; dy = 0.707; player.dir = 'downleft'; }
            else if(keys.downright) { dx = 0.707; dy = 0.707; player.dir = 'downright'; }
            // 组合斜向 (上下+左右)
            else if((keys.up || keys.down) && (keys.left || keys.right)) {
                dx *= 0.707; dy *= 0.707;
                if(keys.up && keys.left) player.dir = 'upleft';
                else if(keys.up && keys.right) player.dir = 'upright';
                else if(keys.down && keys.left) player.dir = 'downleft';
                else if(keys.down && keys.right) player.dir = 'downright';
            }

            let nx = player.x + dx * player.speed;
            let ny = player.y + dy * player.speed;
            nx = Math.max(0, Math.min(W - size, nx));
            ny = Math.max(0, Math.min(H - size, ny));

            const temp = {x:nx, y:ny, w:size, h:size};
            if(!hitWall(temp)) {
                player.x = nx;
                player.y = ny;
            }

            // 射击冷却
            if(fireCd > 0) fireCd--;
            if(keys.fire && fireCd === 0) {
                shoot();
                fireCd = 20;
            }

            // 子弹更新
            for(let i = bullets.length - 1; i >= 0; i--) {
                const b = bullets[i];
                const spd = b.speed;
                if(b.dir === 'up') b.y -= spd;
                else if(b.dir === 'down') b.y += spd;
                else if(b.dir === 'left') b.x -= spd;
                else if(b.dir === 'right') b.x += spd;
                else if(b.dir === 'upleft') { b.x -= spd*0.707; b.y -= spd*0.707; }
                else if(b.dir === 'upright') { b.x += spd*0.707; b.y -= spd*0.707; }
                else if(b.dir === 'downleft') { b.x -= spd*0.707; b.y += spd*0.707; }
                else if(b.dir === 'downright') { b.x += spd*0.707; b.y += spd*0.707; }

                // 边界 & 墙体碰撞
                if(b.x < 0 || b.x > W || b.y < 0 || b.y > H) { bullets.splice(i, 1); continue; }
                if(hitWall(b)) { bullets.splice(i, 1); continue; }

                // 击中敌人
                let bulletUsed = false;
                for(let j = enemies.length - 1; j >= 0; j--) {
                    if(isCollide(b, enemies[j])) {
                        enemies.splice(j, 1);
                        bulletUsed = true;
                        playHit();
                        break;
                    }
                }
                if(bulletUsed) { bullets.splice(i, 1); }
            }

            // 敌人巡逻 (随机转向)
            for(let e of enemies) {
                let ex = e.x, ey = e.y;
                if(e.dir === 'up') ey -= e.speed;
                else if(e.dir === 'down') ey += e.speed;
                else if(e.dir === 'left') ex -= e.speed;
                else if(e.dir === 'right') ex += e.speed;

                const etemp = {x:ex, y:ey, w:size, h:size};
                if(hitWall(etemp) || ex < 0 || ex > W - size || ey < 0 || ey > H - size) {
                    const dirs = ['up','down','left','right'];
                    e.dir = dirs[Math.floor(Math.random() * 4)];
                } else {
                    e.x = ex; e.y = ey;
                }
            }

            // 通关检测
            if(enemies.length === 0) {
                // 防止重复触发
                if(window._winTriggered) return;
                window._winTriggered = true;
                setTimeout(() => {
                    playWinVoice();
                    alert('🎉 恭喜通关！全部敌方坦克已消灭！');
                    location.reload();
                }, 120);
            }
        }

        // ---------- 绘制 ----------
        function draw() {
            ctx.fillStyle = '#0a0c10';
            ctx.fillRect(0, 0, W, H);
            // 网格装饰 (极简)
            ctx.strokeStyle = '#1f2937';
            ctx.lineWidth = 0.5;
            for(let i=0; i<=W; i+=30) {
                ctx.beginPath();
                ctx.moveTo(i, 0);
                ctx.lineTo(i, H);
                ctx.stroke();
                ctx.beginPath();
                ctx.moveTo(0, i);
                ctx.lineTo(W, i);
                ctx.stroke();
            }

            // 墙体
            ctx.fillStyle = '#8b6b4d';
            ctx.shadowColor = '#00000055';
            ctx.shadowBlur = 6;
            for(let w of walls) ctx.fillRect(w.x, w.y, w.w, w.h);
            ctx.shadowBlur = 0;

            // 敌方坦克
            for(let e of enemies) {
                ctx.fillStyle = e.color;
                ctx.shadowBlur = 8;
                ctx.shadowColor = '#ff000066';
                ctx.fillRect(e.x, e.y, e.w, e.h);
                ctx.fillStyle = '#111';
                ctx.shadowBlur = 0;
                ctx.beginPath();
                ctx.arc(e.x + size/2, e.y + size/2, 7, 0, Math.PI*2);
                ctx.fill();
                // 炮管指示
                ctx.fillStyle = '#bbbbbb';
                ctx.fillRect(e.x + size/2 - 2, e.y + 4, 4, 8);
            }

            // 我方坦克
            ctx.shadowBlur = 12;
            ctx.shadowColor = '#33ff3366';
            ctx.fillStyle = player.color;
            ctx.fillRect(player.x, player.y, player.w, player.h);
            ctx.shadowBlur = 0;
            ctx.fillStyle = '#fff';
            ctx.beginPath();
            ctx.arc(player.x + size/2, player.y + size/2, 7, 0, Math.PI*2);
            ctx.fill();
            ctx.fillStyle = '#222';
            ctx.beginPath();
            ctx.arc(player.x + size/2, player.y + size/2, 3, 0, Math.PI*2);
            ctx.fill();
            // 炮管
            ctx.fillStyle = '#ccddff';
            ctx.fillRect(player.x + size/2 - 2, player.y + 4, 4, 8);

            // 子弹
            ctx.shadowBlur = 10;
            ctx.shadowColor = '#ffdd44aa';
            ctx.fillStyle = '#fcee4a';
            for(let b of bullets) ctx.fillRect(b.x, b.y, b.w, b.h);
            ctx.shadowBlur = 0;
        }

        // ---------- 循环 ----------
        function loop() {
            update();
            draw();
            requestAnimationFrame(loop);
        }

        // 防止页面滚动 / 触摸冲突
        document.addEventListener('touchmove', (e) => {
            if(e.target.closest('.game-wrapper')) e.preventDefault();
        }, { passive: false });

        // 启动游戏
        loop();

        // 预加载音频上下文 (点击任意按钮时初始化)
        document.addEventListener('pointerdown', () => {
            initAudio();
        }, { once: true });
        // 额外: 触屏启动
        document.addEventListener('touchstart', () => {
            initAudio();
        }, { once: true });


        // PWA Service Worker 注册
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('./sw.js')
                    .then(reg => console.log('SW registered:', reg.scope))
                    .catch(err => console.log('SW registration failed:', err));
            });
        }

    })();
</script>
</body>
</html>
# 八向坦克大战 · PWA 版

经典八方向坦克大战小游戏，已转换为 Progressive Web App（PWA），支持离线运行、可安装到桌面/手机。

## 在线体验

部署到 GitHub Pages 后访问：
https://你的用户名.github.io/仓库名/

## 本地运行

```bash
npx serve .
```

然后用 Chrome 打开 http://localhost:3000 即可安装。

## GitHub Pages 部署步骤

1. 新建 GitHub 仓库（推荐名字：`tank-battle-pwa`）
2. 把以下文件上传到仓库根目录：
   - `index.html`
   - `manifest.json`
   - `sw.js`
   - `README.md`（可选）
3. 进入仓库 → Settings → Pages
4. Source 选择 `Deploy from a branch`
5. Branch 选择 `main`（或 master），Folder 选择 `/ (root)`
6. 保存后等待 1-2 分钟，页面会显示你的网址
7. 访问该网址，即可看到游戏

## 安装到手机/桌面

1. 用 Chrome / Edge 打开部署后的网址
2. 点击地址栏右侧的 **安装图标**（或菜单 → 安装 八向坦克大战）
3. 确认安装即可像原生 App 一样使用

## 转成安卓 APK（推荐）

1. 访问 [PWABuilder.com](https://www.pwabuilder.com/)
2. 输入你的 GitHub Pages 网址
3. 选择 Android 平台
4. 一键生成并下载 APK
5. 安装到手机测试（支持全屏、离线）

## 图标说明

